<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.rhythme.dao.SongDAO">

    <select id="findAllSongs" resultType="com.example.rhythme.dto.SongDTO">
        SELECT
        song_id AS songId,
        title,
        artist,
        audio_file,
        imageUrl,
        CAST(progress AS UNSIGNED) AS progress
        FROM songs
    </select>

    <select id="findSongById" resultType="com.example.rhythme.dto.SongDTO">
        SELECT
        song_id,
        title,
        artist,
        audio_file,
        imageUrl
        FROM songs
        WHERE song_id = #{songId}
    </select>

</mapper>
